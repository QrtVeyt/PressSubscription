<Window x:Class="PressSubscription.Views.SubscribersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписчики"
        Height="450"
        Width="700">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Style="{StaticResource TopPanelBorder}">

            <StackPanel Orientation="Horizontal">
                <Button Content="Добавить" Click="Add_Click"/>
                <Button Content="Удалить" Click="Delete_Click"/>
            </StackPanel>

        </Border>

        <DataGrid x:Name="SubscribersGrid"
                  Margin="10"
                  AutoGenerateColumns="True"
                  Background="White"
                  BorderBrush="#E0E0E0"/>

    </DockPanel>

</Window>