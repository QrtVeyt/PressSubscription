<Window x:Class="PressSubscription.Views.SubscribersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписчики"
        Height="400"
        Width="600">

    <DockPanel>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="Добавить" Click="Add_Click" Margin="5"/>
            <Button Content="Удалить" Click="Delete_Click" Margin="5"/>
        </StackPanel>

        <DataGrid x:Name="SubscribersGrid" AutoGenerateColumns="True"/>

    </DockPanel>

</Window>