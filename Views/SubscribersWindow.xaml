<Window x:Class="PressSubscription.Views.SubscribersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписчики"
        Height="500"
        Width="800"
        MinHeight="400"
        MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- TOP PANEL -->
        <Border DockPanel.Dock="Top" Style="{StaticResource TopPanelBorder}">

            <StackPanel>
                
                <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="AddButton" Content="Добавить" Click="Add_Click" Margin="5" Padding="10,5"/>
                    <Button x:Name="EditButton" Content="Редактировать" Click="Edit_Click" Margin="5" Padding="10,5"/>
                    <Button x:Name="DeleteButton" Content="Удалить" Click="Delete_Click" Margin="5" Padding="10,5"/>
                </WrapPanel>

                <WrapPanel>
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="SearchBox" Width="250" Margin="5" TextChanged="SearchBox_TextChanged"/>
                    <Button Content="Сбросить" Click="Reset_Click" Margin="15,5,5,5" Padding="10,5"/>
                </WrapPanel>
                
            </StackPanel>

        </Border>

        <!-- GRID -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="10">
            
            <DataGrid x:Name="SubscribersGrid"
                      AutoGenerateColumns="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      MinWidth="700"/>
            
        </ScrollViewer>

    </DockPanel>
</Window>