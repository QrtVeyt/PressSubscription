<Window x:Class="PressSubscription.Views.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PressSubscription.Views"
        Title="Панель администратора - Управление пользователями"
        Height="550"
        Width="900"
        MinHeight="450"
        MinWidth="750"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL -->
        <Border Grid.Row="0" Style="{StaticResource TopPanelBorder}">

            <StackPanel>
                
                <TextBlock Text="Панель администратора" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="Управление пользователями системы" 
                           FontSize="12" 
                           Opacity="0.6" 
                           Margin="0,0,0,15"/>
                
                <WrapPanel>
                    <Button Content="Назначить администратором" 
                            Style="{StaticResource WarningButton}"
                            Click="MakeAdmin_Click" 
                            Margin="5" 
                            Padding="10,5"/>
                    
                    <Button Content="Снять права администратора" 
                            Style="{StaticResource DangerButton}"
                            Click="RemoveAdmin_Click" 
                            Margin="5" 
                            Padding="10,5"/>
                    
                    <Button Content="Заблокировать" 
                            Click="BlockUser_Click" 
                            Margin="5" 
                            Padding="10,5"/>
                    
                    <Button Content="Разблокировать" 
                            Click="UnblockUser_Click" 
                            Margin="5" 
                            Padding="10,5"/>
                    
                    <Button Content="Обновить" 
                            Click="Refresh_Click" 
                            Margin="5" 
                            Padding="10,5"/>
                </WrapPanel>
                
                <TextBlock Text="Внимание: Нельзя изменять права самого себя!" 
                           Foreground="#FF9800" 
                           FontSize="11" 
                           Margin="5,10,0,0"/>
                
                <TextBlock x:Name="AdminCountText" 
                           FontSize="11" 
                           Opacity="0.6" 
                           Margin="5,5,0,0"/>
            </StackPanel>

        </Border>

        <!-- USERS GRID -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="10">
            
            <DataGrid x:Name="UsersGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      MinWidth="850"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="120"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                    
                    <DataGridTextColumn Header="Роль" Width="130">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Role">
                                <Binding.Converter>
                                    <local:RoleToTextConverter/>
                                </Binding.Converter>
                            </Binding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Статус" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="IsActive">
                                <Binding.Converter>
                                    <local:ActiveToTextConverter/>
                                </Binding.Converter>
                            </Binding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Дата регистрации" 
                                        Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                        Width="130"/>
                    
                    <DataGridTextColumn Header="Последний вход" 
                                        Binding="{Binding LastLoginAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                        Width="130"/>
                </DataGrid.Columns>

            </DataGrid>
            
        </ScrollViewer>
        
    </Grid>
</Window>