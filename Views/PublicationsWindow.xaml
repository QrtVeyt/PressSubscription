<Window x:Class="PressSubscription.Views.PublicationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Издания"
        Height="500"
        Width="800"
        Background="#F4F6F8">

    <DockPanel>

        <!-- TOP PANEL -->
        <Border DockPanel.Dock="Top"
                Background="White"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal">

                <Button Content="Добавить"
                        Click="Add_Click"
                        Margin="5"
                        Padding="10,5"/>

                <Button Content="Удалить"
                        Click="Delete_Click"
                        Margin="5"
                        Padding="10,5"/>

            </StackPanel>

        </Border>

        <!-- LIST -->
        <ListView x:Name="PublicationsList"
                  Background="Transparent"
                  BorderThickness="0"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <!-- GRID LAYOUT -->
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <!-- CARD TEMPLATE -->
            <ListView.ItemTemplate>

                <DataTemplate>

                    <Border Width="220"
                            Margin="10"
                            Padding="10"
                            Background="White"
                            CornerRadius="12"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">

                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              ShadowDepth="2"
                                              Opacity="0.15"/>
                        </Border.Effect>

                        <StackPanel>

                            <Image Source="{Binding Image}"
                                   Height="120"
                                   Stretch="UniformToFill"
                                   Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding Title}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#222"/>

                            <TextBlock Text="{Binding Publisher}"
                                       Opacity="0.7"
                                       Margin="0,2,0,0"/>

                            <TextBlock Text="{Binding PricePerMonth, StringFormat='Цена: {0} ₽/мес'}"
                                       Margin="0,6,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#2E7D32"/>

                        </StackPanel>

                    </Border>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>

    </DockPanel>

</Window>