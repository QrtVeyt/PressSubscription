<Window x:Class="PressSubscription.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписка на издания"
        Height="350"
        Width="400">

    <StackPanel Margin="20">

        <Button Content="Подписчики" Click="Subscribers_Click" Margin="0,5"/>
        <Button Content="Издания" Click="Publications_Click" Margin="0,5"/>
        <Button Content="Подписки" Click="Subscriptions_Click" Margin="0,5"/>
        <Button Content="Импорт Excel" Click="Import_Click" Margin="0,5"/>

    </StackPanel>

</Window>