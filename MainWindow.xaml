<Window x:Class="PressSubscription.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписка на издания"
        Height="500"
        Width="550"
        MinHeight="400"
        MinWidth="500"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="White"
                Padding="12"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">

            <StackPanel Orientation="Horizontal">
                <Image Source="Assets/logo.png"
                       Width="40"
                       Height="40"
                       Margin="0,0,10,0"/>
                <TextBlock Text="Система подписки на издания"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <StackPanel Margin="20">
            
            <Button x:Name="AdminPanelButton" 
                    Content="Панель администратора" 
                    Click="AdminPanel_Click" 
                    Margin="0,5" 
                    Padding="10,5"
                    Background="#FF9800" 
                    Foreground="White"
                    Visibility="Collapsed"/>
            
            <Button Content="Подписчики" Click="Subscribers_Click" Margin="0,5" Padding="10,5"/>
            <Button Content="Издания" Click="Publications_Click" Margin="0,5" Padding="10,5"/>
            <Button Content="Подписки" Click="Subscriptions_Click" Margin="0,5" Padding="10,5"/>
            
            <Button x:Name="ImportButton" 
                    Content="Импорт Excel" 
                    Click="Import_Click" 
                    Margin="0,5" 
                    Padding="10,5"
                    Visibility="Collapsed"/>
            
            <Button Content="Выйти" 
                    Click="Logout_Click" 
                    Margin="0,20,0,5" 
                    Padding="10,5" 
                    Background="#D32F2F" 
                    Foreground="White"/>
            
            <TextBlock x:Name="UserInfoText" 
                       Margin="0,20,0,0" 
                       TextAlignment="Center" 
                       FontSize="11" 
                       Opacity="0.6"/>
        </StackPanel>

    </DockPanel>
</Window>